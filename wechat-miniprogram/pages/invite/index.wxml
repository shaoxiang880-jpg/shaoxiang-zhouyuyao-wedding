<scroll-view class="page" scroll-y enhanced show-scrollbar="{{false}}">
  <view class="audio-mark">♪</view>

  <view class="cover-block">
    <text class="eyebrow">WEDDING INVITATION</text>
    <image
      class="magazine-page first-page"
      src="{{magazinePages[0]}}"
      mode="widthFix"
      show-menu-by-longpress="true"
    />
    <view class="name-row">
      <view class="name-item">
        <text class="role">新郎</text>
        <text class="cn-name">邵翔</text>
        <text class="en-name">SHAOXIANG</text>
      </view>
      <text class="and">&amp;</text>
      <view class="name-item">
        <text class="role">新娘</text>
        <text class="cn-name">周钰瑶</text>
        <text class="en-name">ZHOUYUYAO</text>
      </view>
    </view>
    <view class="date-line">
      <text>2026</text>
      <text>/</text>
      <text>09</text>
      <text>/</text>
      <text>12</text>
    </view>
  </view>

  <view class="invite-copy">
    <text>诚挚地邀请您参加</text>
    <text class="copy-strong">我们的婚礼</text>
    <text>期待与您相见，在我们最重要的一天</text>
    <text class="slash">/</text>
    <text class="copy-en">Sincerely invite you to participate</text>
    <text class="copy-en">Our wedding</text>
    <text class="copy-en">Looking forward to meeting you on our most important day</text>
  </view>

  <block wx:for="{{magazinePages}}" wx:key="*this">
    <image
      wx:if="{{index > 0}}"
      class="magazine-page"
      src="{{item}}"
      mode="widthFix"
      lazy-load="{{index > 1}}"
      show-menu-by-longpress="true"
    />
  </block>

  <view class="info-panel">
    <view class="section-title">
      <text class="script">Wedding date</text>
      <text class="section-cn">婚礼信息</text>
    </view>
    <view class="date-card">
      <view class="date-side">
        <text>SEP</text>
        <text>2026</text>
      </view>
      <view class="date-main">
        <text class="date-number">09.12</text>
        <text class="date-sub">SATURDAY</text>
      </view>
      <view class="date-side">
        <text>星期六</text>
        <text>午宴</text>
      </view>
    </view>
    <view class="venue">
      <text class="venue-name">天港禧悦 · 宴会中心</text>
      <text class="venue-sub">海曙丽园南路店</text>
      <text class="venue-address">浙江省宁波市海曙区丽园南路</text>
      <button class="nav-button" bindtap="openLocation">一键导航</button>
    </view>
  </view>

  <view class="timeline">
    <view class="timeline-item" wx:for="{{timeline}}" wx:key="title">
      <text class="timeline-title">{{item.title}}</text>
      <text class="timeline-heart">♡</text>
      <text class="timeline-time">{{item.time}}</text>
    </view>
  </view>

  <view class="footer">
    <text class="footer-cn">邀请最挚爱的您来一场关于爱的旅行</text>
    <text class="footer-cn">见证我们 爱的启程</text>
    <text class="footer-sign">Shao Xiang & Zhou Yu Yao</text>
    <button class="share-button" open-type="share">分享请柬</button>
  </view>
</scroll-view>
