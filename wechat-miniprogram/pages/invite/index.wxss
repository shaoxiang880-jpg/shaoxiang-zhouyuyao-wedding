page {
  background: #f4eedf;
  color: #221f1c;
}

.page {
  height: 100vh;
  background:
    radial-gradient(circle at 18% 8%, rgba(255, 255, 255, 0.65), transparent 22%),
    linear-gradient(180deg, #f8f2e6 0%, #efe5d2 100%);
}

.audio-mark {
  position: fixed;
  top: 34rpx;
  right: 30rpx;
  z-index: 10;
  width: 60rpx;
  height: 60rpx;
  border: 1rpx solid rgba(90, 75, 57, 0.28);
  border-radius: 999rpx;
  text-align: center;
  line-height: 60rpx;
  color: #7f6a4e;
  font-size: 30rpx;
  background: rgba(248, 242, 230, 0.8);
}

.cover-block {
  min-height: 100vh;
  padding: 66rpx 42rpx 80rpx;
  box-sizing: border-box;
}

.eyebrow {
  display: block;
  text-align: center;
  margin-bottom: 38rpx;
  font-size: 22rpx;
  letter-spacing: 8rpx;
  color: #433b32;
}

.magazine-page {
  display: block;
  width: 100%;
  margin: 0 auto 34rpx;
}

.first-page {
  margin-bottom: 48rpx;
}

.name-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 0 12rpx;
}

.name-item {
  width: 280rpx;
  text-align: center;
}

.name-item text {
  display: block;
}

.role {
  color: #7f7469;
  font-size: 21rpx;
  margin-bottom: 12rpx;
}

.cn-name {
  font-size: 46rpx;
  line-height: 1.2;
  letter-spacing: 4rpx;
}

.en-name {
  margin-top: 10rpx;
  font-size: 18rpx;
  letter-spacing: 4rpx;
  color: #766a5c;
}

.and {
  width: 52rpx;
  padding-top: 54rpx;
  color: #8e4d46;
  font-size: 34rpx;
  font-style: italic;
  text-align: center;
}

.date-line {
  display: flex;
  justify-content: center;
  gap: 14rpx;
  margin-top: 58rpx;
  font-size: 22rpx;
  color: #352f29;
  letter-spacing: 2rpx;
}

.invite-copy {
  min-height: 620rpx;
  padding: 128rpx 76rpx 118rpx;
  text-align: center;
  box-sizing: border-box;
}

.invite-copy text {
  display: block;
  font-size: 27rpx;
  line-height: 2.15;
  letter-spacing: 2rpx;
}

.copy-strong {
  font-size: 34rpx !important;
  margin: 8rpx 0;
}

.slash {
  color: #8e4d46;
  font-size: 34rpx !important;
  margin: 28rpx 0 20rpx;
  font-style: italic;
}

.copy-en {
  font-size: 18rpx !important;
  line-height: 1.8 !important;
  color: #756858;
  letter-spacing: 1rpx !important;
}

.info-panel {
  padding: 92rpx 44rpx 72rpx;
}

.section-title {
  text-align: center;
  margin-bottom: 42rpx;
}

.section-title text {
  display: block;
}

.script {
  color: #8e4d46;
  font-size: 30rpx;
  font-style: italic;
}

.section-cn {
  margin-top: 8rpx;
  color: #3b332b;
  font-size: 24rpx;
  letter-spacing: 4rpx;
}

.date-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 34rpx 24rpx;
  border-top: 1rpx solid rgba(77, 64, 49, 0.22);
  border-bottom: 1rpx solid rgba(77, 64, 49, 0.22);
}

.date-side {
  width: 132rpx;
  text-align: center;
  color: #66594a;
  font-size: 22rpx;
  line-height: 1.8;
}

.date-side text,
.date-main text {
  display: block;
}

.date-main {
  flex: 1;
  text-align: center;
}

.date-number {
  color: #8e1f28;
  font-size: 78rpx;
  line-height: 1;
  letter-spacing: 2rpx;
}

.date-sub {
  margin-top: 12rpx;
  color: #5d5145;
  font-size: 19rpx;
  letter-spacing: 3rpx;
}

.venue {
  margin-top: 62rpx;
  text-align: center;
}

.venue text {
  display: block;
}

.venue-name {
  font-size: 34rpx;
  letter-spacing: 2rpx;
}

.venue-sub {
  margin-top: 14rpx;
  font-size: 27rpx;
  color: #5d5145;
}

.venue-address {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #817565;
}

.nav-button,
.share-button {
  width: 310rpx;
  height: 76rpx;
  line-height: 76rpx;
  margin-top: 38rpx;
  border: 1rpx solid #6d563d;
  border-radius: 0;
  background: transparent;
  color: #5f4a33;
  font-size: 23rpx;
  letter-spacing: 4rpx;
}

.nav-button::after,
.share-button::after {
  border: 0;
}

.timeline {
  display: flex;
  justify-content: space-between;
  padding: 56rpx 42rpx 86rpx;
  text-align: center;
}

.timeline-item {
  width: 31%;
}

.timeline-item text {
  display: block;
}

.timeline-title {
  font-size: 24rpx;
  color: #2f2923;
}

.timeline-heart {
  margin: 18rpx 0;
  color: #8e4d46;
  font-size: 34rpx;
}

.timeline-time {
  color: #5d5145;
  font-size: 23rpx;
  letter-spacing: 1rpx;
}

.footer {
  padding: 98rpx 54rpx 120rpx;
  text-align: center;
}

.footer text {
  display: block;
}

.footer-cn {
  color: #2f2923;
  font-size: 29rpx;
  line-height: 2;
  letter-spacing: 2rpx;
}

.footer-sign {
  margin-top: 40rpx;
  color: #8e4d46;
  font-size: 34rpx;
  font-style: italic;
}
