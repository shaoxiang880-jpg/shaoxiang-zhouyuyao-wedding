page {
  background: #f7f1e8;
  color: #2c2c2c;
}

.page {
  height: 100vh;
  background: #f7f1e8;
}

.section {
  box-sizing: border-box;
  background: #f7f1e8;
}

.music-mark {
  position: fixed;
  top: 34rpx;
  right: 32rpx;
  z-index: 20;
  width: 68rpx;
  height: 68rpx;
  line-height: 68rpx;
  text-align: center;
  border-radius: 999rpx;
  border: 1rpx solid rgba(107, 94, 84, 0.24);
  background: rgba(247, 241, 232, 0.88);
  color: #a85d50;
  font-size: 30rpx;
}

.hero {
  min-height: 100vh;
  padding: 72rpx 40rpx 54rpx;
}

.hero-title {
  display: block;
  text-align: center;
  color: #6b5e54;
  font-size: 22rpx;
  letter-spacing: 9rpx;
  margin-bottom: 42rpx;
}

.hero-photo-wrap {
  position: relative;
  width: 100%;
  min-height: 240rpx;
}

.hero-preview,
.hero-photo {
  display: block;
  width: 100%;
}

.hero-photo {
  position: absolute;
  left: 0;
  top: 0;
}

.hero-names {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 58rpx 10rpx 28rpx;
}

.name-block {
  width: 290rpx;
  text-align: center;
}

.name-block text {
  display: block;
}

.role {
  color: #8a7e72;
  font-size: 21rpx;
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}

.cn-name {
  color: #2c2c2c;
  font-size: 46rpx;
  line-height: 1.2;
  letter-spacing: 5rpx;
}

.en-name {
  margin-top: 10rpx;
  color: #6b5e54;
  font-size: 18rpx;
  letter-spacing: 4rpx;
}

.script-name {
  margin-top: 18rpx;
  color: #a85d50;
  font-size: 27rpx;
  font-style: italic;
}

.amp {
  width: 50rpx;
  padding-top: 78rpx;
  color: #a85d50;
  text-align: center;
  font-size: 34rpx;
  font-style: italic;
}

.date-stack {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #2c2c2c;
  font-size: 54rpx;
  line-height: 1;
  margin-top: 8rpx;
}

.date-slash {
  color: #8a7e72;
  font-size: 32rpx;
  margin: 10rpx 0;
}

.invite {
  padding: 130rpx 70rpx 90rpx;
  text-align: center;
}

.copy-cn text,
.copy-en text {
  display: block;
}

.copy-cn {
  color: #2c2c2c;
  font-size: 30rpx;
  line-height: 2.25;
  letter-spacing: 2rpx;
}

.copy-main {
  font-size: 38rpx;
  letter-spacing: 6rpx;
}

.decor-slash {
  display: block;
  margin: 42rpx 0 30rpx;
  color: #a85d50;
  font-size: 42rpx;
  font-style: italic;
}

.copy-en {
  color: #6b5e54;
  font-size: 21rpx;
  line-height: 1.9;
}

.thin-line {
  width: 1rpx;
  height: 118rpx;
  margin: 76rpx auto 0;
  background: linear-gradient(180deg, transparent, rgba(107, 94, 84, 0.34), transparent);
}

.envelope {
  padding: 80rpx 54rpx 86rpx;
}

.envelope-card {
  position: relative;
  padding: 88rpx 44rpx 54rpx;
  background: #fbf7f0;
  border: 1rpx solid rgba(107, 94, 84, 0.14);
  box-shadow: 0 20rpx 58rpx rgba(86, 72, 58, 0.12);
  transform: rotate(-2deg);
  overflow: hidden;
}

.flap {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 130rpx;
  background: linear-gradient(180deg, #ede8de, #fbf7f0);
  clip-path: polygon(0 0, 50% 68%, 100% 0);
}

.envelope-image {
  position: relative;
  z-index: 1;
  display: block;
  width: 100%;
  height: 660rpx;
  transform: rotate(-2deg);
}

.envelope-text {
  position: relative;
  z-index: 1;
  text-align: center;
  margin-top: 50rpx;
}

.envelope-text text {
  display: block;
}

.love,
.script {
  color: #a85d50;
  font-size: 48rpx;
  font-style: italic;
}

.label {
  margin-top: 10rpx;
  color: #6b5e54;
  font-size: 20rpx;
  letter-spacing: 8rpx;
}

.sub {
  margin-top: 18rpx;
  color: #6b5e54;
  font-size: 22rpx;
  font-style: italic;
}

.info,
.timeline,
.story,
.closing {
  padding: 86rpx 44rpx;
}

.section-title {
  text-align: center;
  margin-bottom: 44rpx;
}

.section-title text {
  display: block;
}

.cn-title {
  margin-top: 8rpx;
  color: #2c2c2c;
  font-size: 24rpx;
  letter-spacing: 6rpx;
}

.date-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 176rpx;
  padding: 30rpx 24rpx;
  background: rgba(255, 255, 255, 0.56);
  border: 1rpx solid rgba(107, 94, 84, 0.15);
  box-shadow: 0 16rpx 44rpx rgba(86, 72, 58, 0.08);
}

.date-side {
  width: 134rpx;
  text-align: center;
  color: #6b5e54;
  font-size: 24rpx;
  line-height: 1.7;
}

.date-side text,
.date-mid text,
.venue text,
.timeline-item text,
.story-copy text,
.heart-note text,
.closing-copy text {
  display: block;
}

.date-mid {
  flex: 1;
  text-align: center;
  border-left: 1rpx solid rgba(107, 94, 84, 0.16);
  border-right: 1rpx solid rgba(107, 94, 84, 0.16);
}

.date-number {
  color: #2c2c2c;
  font-size: 72rpx;
  line-height: 1;
  letter-spacing: 2rpx;
}

.date-en {
  margin-top: 12rpx;
  color: #6b5e54;
  font-size: 20rpx;
}

.venue {
  margin-top: 72rpx;
  text-align: center;
}

.venue-name {
  color: #2c2c2c;
  font-size: 34rpx;
  letter-spacing: 2rpx;
}

.venue-sub {
  color: #6b5e54;
  font-size: 27rpx;
  margin-top: 14rpx;
}

.venue-address {
  color: #8a7e72;
  font-size: 22rpx;
  margin-top: 12rpx;
}

.map-button,
.share-button {
  width: 300rpx;
  height: 76rpx;
  line-height: 76rpx;
  margin-top: 40rpx;
  border-radius: 999rpx;
  border: 0;
  background: #6b4e31;
  color: #fff;
  font-size: 23rpx;
  letter-spacing: 4rpx;
}

.map-button::after,
.share-button::after {
  border: 0;
}

.timeline-row {
  display: flex;
  justify-content: space-between;
}

.timeline-item {
  width: 31%;
  text-align: center;
}

.timeline-title {
  color: #2c2c2c;
  font-size: 24rpx;
}

.timeline-en {
  min-height: 48rpx;
  color: #6b5e54;
  font-size: 18rpx;
  margin-top: 8rpx;
}

.timeline-icon {
  color: #a85d50;
  font-size: 36rpx;
  margin: 16rpx 0;
}

.timeline-time {
  color: #2c2c2c;
  font-size: 23rpx;
}

.wide-photo {
  display: block;
  width: 100%;
  margin-bottom: 56rpx;
}

.story-copy {
  text-align: center;
  color: #2c2c2c;
  font-size: 31rpx;
  line-height: 2.1;
  letter-spacing: 2rpx;
  margin: 30rpx 0 58rpx;
}

.story-en {
  margin-top: 18rpx;
  color: #6b5e54;
  font-size: 20rpx;
  line-height: 1.8;
  letter-spacing: 0;
}

.grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-bottom: 58rpx;
}

.grid-img {
  width: 100%;
  height: 430rpx;
}

.polaroid {
  width: 400rpx;
  margin: 54rpx auto 0;
  padding: 18rpx 18rpx 44rpx;
  background: #fff;
  box-shadow: 0 12rpx 30rpx rgba(60, 48, 36, 0.12);
  transform: rotate(-2deg);
  text-align: center;
}

.polaroid-img {
  display: block;
  width: 100%;
}

.polaroid text {
  display: block;
  margin-top: 20rpx;
  color: #6b5e54;
  font-size: 22rpx;
  letter-spacing: 3rpx;
}

.closing-grid {
  display: grid;
  grid-template-columns: 1.08fr 0.92fr;
  gap: 22rpx;
  align-items: center;
}

.closing-photo {
  display: block;
  width: 100%;
}

.heart-note {
  min-height: 280rpx;
  padding: 40rpx 22rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  box-sizing: border-box;
  text-align: center;
  background: rgba(255, 255, 255, 0.58);
  border: 1rpx solid rgba(107, 94, 84, 0.15);
  border-radius: 50% 50% 48% 52% / 42% 42% 58% 58%;
  color: #6b5e54;
  font-size: 19rpx;
  line-height: 1.8;
}

.closing-copy {
  margin-top: 66rpx;
  text-align: center;
  color: #2c2c2c;
  font-size: 30rpx;
  line-height: 2.1;
  letter-spacing: 2rpx;
}

.closing-en {
  margin-top: 20rpx;
  color: #6b5e54;
  font-size: 20rpx;
  line-height: 1.8;
  letter-spacing: 0;
}

.signature {
  margin-top: 42rpx;
  color: #a85d50;
  font-size: 36rpx;
  font-style: italic;
}
